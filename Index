  font-size:1.25rem;line-height:1.8;
  color:rgba(247,241,230,.75);
  max-width:500px;margin:1.2rem auto 2.5rem;
}
.order-quote::before{content:'«  '}
.order-quote::after{content:'  »'}
.order-price{
  font-family:'Josefin Sans',sans-serif;
  font-size:.6rem;letter-spacing:.35em;
  color:var(--sage);margin-bottom:1.2rem;
}
.order-btns{
  display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;
  margin-bottom:1.8rem;
}
.order-note{
  font-family:'Josefin Sans',sans-serif;
  font-size:.58rem;letter-spacing:.22em;
  color:rgba(94,125,82,.55);
}

/* === AUDIO PLAYER === */
.audio-float{
  position:fixed;bottom:1.8rem;right:1.8rem;z-index:400;
  display:flex;align-items:center;gap:.8rem;
  background:rgba(8,15,8,.92);
  border:1px solid rgba(212,175,80,.22);
  border-radius:50px;padding:.65rem 1.2rem;
  backdrop-filter:blur(14px);cursor:pointer;
  transition:border-color .3s;
  box-shadow:0 8px 30px rgba(0,0,0,.5);
}
.audio-float:hover{border-color:var(--gilt)}
.audio-ico{font-size:1.1rem}
.audio-lbl{
  font-family:'Josefin Sans',sans-serif;
  font-size:.58rem;letter-spacing:.22em;
  color:rgba(94,125,82,.8);text-transform:uppercase;
}
.waves{display:flex;align-items:center;gap:2px}
.w{
  width:2px;background:var(--gilt);border-radius:2px;
  animation:wv .9s ease-in-out infinite;
}
.w1{height:6px;animation-delay:0s}
.w2{height:12px;animation-delay:.12s}
.w3{height:8px;animation-delay:.24s}
.w4{height:14px;animation-delay:.06s}
.w5{height:6px;animation-delay:.18s}
@keyframes wv{0%,100%{transform:scaleY(1)}50%{transform:scaleY(.25)}}
.w.off{animation-play-state:paused;opacity:.3}

/* === FOOTER === */
footer{
  background:#040808;
  padding:3rem 2rem;text-align:center;
  border-top:1px solid rgba(212,175,80,.08);
}
.ft-logo{
  font-family:'Playfair Display',serif;
  font-size:1.1rem;color:var(--gilt);
  font-style:italic;margin-bottom:.5rem;
}
.ft-sub{
  font-family:'Josefin Sans',sans-serif;
  font-size:.58rem;letter-spacing:.28em;
  color:var(--sage);margin-bottom:.4rem;
}
.ft-site a{
  color:var(--gilt);text-decoration:none;
  font-family:'Josefin Sans',sans-serif;
  font-size:.6rem;letter-spacing:.2em;
  transition:color .3s;
}
.ft-site a:hover{color:var(--shine)}
.ft-copy{
  margin-top:1.5rem;font-size:.82rem;
  color:rgba(94,125,82,.35);font-style:italic;
}
</style>
